{
  "manifest_version": 3,
  "name": "SERP Telemetry Inspector",
  "version": "3.1",
  "description": "Captures and decodes Google /gen_204 SERP telemetry signals in real time.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/*", "https://google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injector.js"],
      "matches": ["https://www.google.com/*", "https://google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SERP Telemetry Inspector",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
